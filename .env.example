# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# ── LLM providers ─────────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key
ANTHROPIC_API_KEY=                    # optional — only needed for Claude models
GITHUB_COPILOT_API_KEY=               # optional — only needed for Copilot models

# ── Storage (SeaweedFS) ───────────────────────────────────────────────────────
SEAWEEDFS_FILER_URL=http://localhost:8888
SEAWEEDFS_PUBLIC_URL=http://localhost:8888   # public-facing base URL for image links

# ── Search (Meilisearch) ──────────────────────────────────────────────────────
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_API_KEY=dev-master-key

# ── Debug ─────────────────────────────────────────────────────────────────────
DEBUG=false
